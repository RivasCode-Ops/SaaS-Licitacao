{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["POSTGRES_URL", "AUTH_SECRET", "RESEND_API_KEY", "EMAIL_FROM", "CRON_SECRET", "BASE_URL", "SENTRY_DSN", "NEXT_PUBLIC_SENTRY_DSN", "SENTRY_ORG", "SENTRY_PROJECT", "UPSTASH_REDIS_REST_URL", "UPSTASH_REDIS_REST_TOKEN", "R2_ACCOUNT_ID", "R2_ACCESS_KEY_ID", "R2_SECRET_ACCESS_KEY", "R2_BUCKET", "R2_PUBLIC_URL", "INNGEST_EVENT_KEY", "INNGEST_SIGNING_KEY"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {},
    "db:generate": {},
    "db:migrate": {
      "dependsOn": ["db:generate"]
    },
    "db:seed": {
      "dependsOn": ["db:generate"]
    }
  }
}
