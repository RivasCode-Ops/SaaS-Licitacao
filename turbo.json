{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": ["POSTGRES_URL", "AUTH_SECRET", "RESEND_API_KEY", "EMAIL_FROM", "CRON_SECRET", "BASE_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {},
    "db:generate": {},
    "db:migrate": {
      "dependsOn": ["db:generate"]
    },
    "db:seed": {
      "dependsOn": ["db:generate"]
    }
  }
}
